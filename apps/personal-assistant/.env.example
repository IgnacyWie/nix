# Personal Assistant Agent environment example.
# Copy to apps/personal-assistant/.env on eta. The .env file is an Assistant Secret Projection and must stay untracked.

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=CHANGEME

# Only this Telegram numeric user id may talk to the assistant.
ASSISTANT_ALLOWLISTED_TELEGRAM_USER_ID=123456789

# Durable state for polling offsets and future assistant state.
ASSISTANT_DURABLE_STATE_DIR=/Users/ignacywielogorski/Services/data/personal-assistant

# Hosted Pi model selection. Provider/model ids must exist in Pi's model registry.
PI_MODEL_PROVIDER=anthropic
PI_MODEL_ID=claude-sonnet-4-20250514
PI_THINKING_LEVEL=off

# Optional non-interactive Pi auth projection for launchd. Prefer Keychain/1Password materialization.
# ANTHROPIC_API_KEY=CHANGEME
