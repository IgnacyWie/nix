#!/usr/bin/env sh

set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"

. "${SCRIPT_DIR}/nix-env.sh"

cd "${REPO_ROOT}"
exec "${NIX_BIN}" ${NIX_FLAKE_FLAGS} eval ".#nixosConfigurations.eta-cloud.config.system.build.toplevel.drvPath"
