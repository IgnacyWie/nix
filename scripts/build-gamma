#!/usr/bin/env sh

set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"

. "${SCRIPT_DIR}/nix-env.sh"

cd "${REPO_ROOT}"

echo "Evaluating gamma Darwin system output..."
"${NIX_BIN}" ${NIX_FLAKE_FLAGS} eval --raw .#darwinConfigurations.gamma.system >/dev/null

echo "Building gamma Darwin system closure..."
exec "${NIX_BIN}" ${NIX_FLAKE_FLAGS} build --no-link .#darwinConfigurations.gamma.system
