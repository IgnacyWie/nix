#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

brewfile="$tmpdir/Brewfile"

cd "$repo_root"
nix eval --raw .#darwinConfigurations.gamma.config.homebrew.brewfile > "$brewfile"

printf 'Using evaluated gamma Brewfile: %s\n\n' "$brewfile"

set +e
HOMEBREW_NO_AUTO_UPDATE=1 brew bundle cleanup --file "$brewfile" --zap "$@"
status=$?
set -e

cat <<'EOF'

Manual cleanup notes:
- Homebrew exits non-zero when cleanup would remove packages. That is expected
  in preview mode and does not mean the repo evaluation failed.
- "Refusing to load ... from untrusted tap" means Homebrew needs an explicit
  manual trust decision before it can inspect and zap that cask or formula.
  Trust only the narrow cask/formula shown by Homebrew unless the whole tap is
  intentionally trusted.
- "Refusing to untap ... because it contains installed formulae or casks" means
  at least one installed package from that tap is still present. Either add that
  package to modules/darwin/homebrew.nix if it belongs in the baseline, or
  uninstall it manually and rerun this preview.
- Once the preview shows only removals you accept, run make apply-gamma. The
  nix-darwin Homebrew activation is configured with cleanup = "zap".
EOF

printf '\nHomebrew cleanup preview exited with status %s.\n' "$status"
