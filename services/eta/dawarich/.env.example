# Copy to .env on eta and fill secret values from Vaultwarden after the
# Keystone Service has been restored. Do not commit .env or real secrets.

DAWARICH_HOST=map.mac.wie.dev
RAILS_ENV=development
POSTGRES_USER=postgres
POSTGRES_DB=dawarich_development
POSTGRES_PASSWORD=set-me
SECRET_KEY_BASE=set-me
APPLICATION_HOSTS=localhost,::1,127.0.0.1,map.mac.wie.dev
APPLICATION_PROTOCOL=http
TIME_ZONE=Europe/Amsterdam
MIN_MINUTES_SPENT_IN_CITY=60
BACKGROUND_PROCESSING_CONCURRENCY=10
RAILS_LOG_TO_STDOUT=true
SELF_HOSTED=true
STORE_GEODATA=true
