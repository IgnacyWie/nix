# Copy to .env on eta and keep the local file untracked.
# Do not commit .env or real secrets.

# Traefik host for browser-based local chat through the Tailscale-only Home
# Server Access Model.
OPEN_WEBUI_HOST=ai.mac.wie.dev

# Traefik host for Paperless-AI. This UI is useful for setup, manual document
# processing, and RAG/chat features, so it is routed through the Ingress Layer.
PAPERLESS_AI_HOST=paperless-ai.mac.wie.dev

# Application authentication is required. Open WebUI stores users and chat state
# in ~/Services/data/local-ai/open-webui. On fresh data, temporarily set
# OPEN_WEBUI_ENABLE_SIGNUP=true to create the first owner/admin account, then
# set it back to false and restart the stack.
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_ENABLE_SIGNUP=false

# OMLX is host-managed on eta and exposes an OpenAI-compatible local API on
# 127.0.0.1:8000. Containers reach it through the Docker host bridge.
OMLX_OPENAI_API_BASE_URL=http://host.docker.internal:8000/v1
OMLX_OPENAI_API_KEY=omlx-local-no-key
OPEN_WEBUI_ENABLE_OLLAMA_API=false

# Paperless-AI connects to the Tier 1 Paperless Service Stack with a dedicated
# Paperless API credential. Create a Paperless user/token specifically for
# Paperless-AI, store the real token in the Secret Store, and put only the local
# projection in .env on eta.
PAPERLESS_AI_PAPERLESS_API_URL=http://paperless-webserver-1:8000/api
PAPERLESS_AI_PAPERLESS_USERNAME=set-me-paperless-ai-user
PAPERLESS_AI_PAPERLESS_API_TOKEN=set-me-paperless-api-token

# Paperless-AI uses the OpenAI-compatible OMLX endpoint through its custom
# provider settings. Set PAPERLESS_AI_OMLX_MODEL to an available OMLX model from
# curl http://127.0.0.1:8000/v1/models on eta.
PAPERLESS_AI_PROVIDER=custom
PAPERLESS_AI_OMLX_MODEL=set-me-omlx-model

# Paperless-AI UI/API authentication. The app supports login/JWT sessions after
# initial setup plus API-key authentication for API calls. Replace both values
# with long random strings in the untracked .env file.
PAPERLESS_AI_INITIAL_SETUP=yes
PAPERLESS_AI_API_KEY=set-me-random-api-key
PAPERLESS_AI_JWT_SECRET=set-me-random-jwt-secret

# Mark AI-written metadata visibly in Paperless so later audits can distinguish
# model-written tags/metadata from manually curated metadata.
PAPERLESS_AI_ADD_AI_PROCESSED_TAG=yes
PAPERLESS_AI_PROCESSED_TAG_NAME=ai-written-metadata

# Keep Paperless-AI RAG disabled until the service has been bootstrapped and the
# data footprint is intentionally accepted. The metadata-assistance path does
# not require Local AI to become Tier 1.
PAPERLESS_AI_RAG_SERVICE_ENABLED=false
PAPERLESS_AI_PORT=3000

USERMAP_UID=501
USERMAP_GID=20
TZ=Europe/Amsterdam
