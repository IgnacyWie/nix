# Copy to .env on eta and fill values from the Bootstrap Secret Set.
# Do not commit .env or real secret values.

VAULTWARDEN_DOMAIN=https://vaultwarden.example.ts.net
VAULTWARDEN_HOST=vaultwarden.example.ts.net
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_WEBSOCKET_ENABLED=true

# Generate with: openssl rand -base64 48
ADMIN_TOKEN=set-me
